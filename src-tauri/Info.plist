<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Screenshots use macOS Screen Recording. Text/URL capture is done with the
       Accessibility API + CGEvent keystrokes (no Apple Events), so Shiro needs
       NO Automation permission — there's deliberately no NSAppleEventsUsageDescription. -->
  <key>NSScreenCaptureUsageDescription</key>
  <string>Shiro needs screen recording access to capture screenshots that you attach to saved items.</string>
</dict>
</plist>
